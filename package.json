{
  "name": "immersion-os",
  "productName": "Immersion OS",
  "version": "1.2.0",
  "description": "A desktop dashboard for tracking immersion learning.",
  "author": "ljpn2vw",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.immersion.os",
    "win": {
      "target": "nsis",
      "icon": "logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "extraResources": [
      "assets/**"
    ]
  }
}
